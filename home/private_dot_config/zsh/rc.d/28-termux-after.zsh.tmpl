{{- if eq .chezmoi.os "android" -}}
#!/usr/bin/env zsh

run_bg() {
  local cmd_name log_file
  cmd_name="$1"

  if pgrep -f "$cmd_name" >/dev/null; then
    return
  fi

  log_file="$TMPDIR/${cmd_name}_$(date +%Y%m%d).log"
  "$@" >>"$log_file" 2>&1 &
  ln -sf "$log_file" "$PREFIX/tmp/${cmd_name}.log"
  echo "✅ $cmd_name started"
}

[ -z "$SSH_CONNECTION" ] || return

(
  if ! pgrep -f "onvd" > /dev/null; then
    onvd
  fi
  
  zinit cd 0x39c/selver

  export ROCKET_PORT=2001
  export WEB_VAULT_FOLDER="./web-vault"
  export DATA_FOLDER="$XDG_DATA_HOME/vault"
  
  run_bg caddy run --config config/Caddyfile
  run_bg vaultwarden
  run_bg favicon_server --port 2002
  run_bg keepalive config/keepalive.amr
  run_bg rclone serve webdav $HOME/xCloud/dav --addr localhost:2004 --user inx --pass wudile
) > /dev/null

{{- end }}

# brew hook


typeset -gA __CMD_WRAPPERS
__CMD_WRAPPERS=(sudo 1 time 1 env 1 command 1 exec 1 nohup 1 nice 1 systemd-run 1)

__extract_real_command() {
    local -a tokens=(${(z)1})
    local token

    for token in $tokens; do
        if [[ "$token" =~ ^[a-zA-Z_][a-zA-Z0-9_]*= ]]; then
            continue
        fi

        if [[ -n "${__CMD_WRAPPERS[$token]}" ]]; then
            continue
        fi

        if [[ "$token" == -* ]]; then
            continue
        fi

        echo "$token"
        return
    done
    
    echo "${tokens[1]}"
}

__preexec_remember_command() {
  [[ $# -eq 0 ]] && return

  local cmd=$(__extract_real_command $1)
  local info=$(whence -v -- "$cmd" 2>/dev/null)

  __remember_command=($cmd $1)
  # print -u2 -P "%F{yellow}$info%f"
  # print -u2 -P "%F{yellow}${${(l:${#info}::-:)}}%f"
}


__preexec_del_zinit_sched() {
  [[ "${chpwd_functions[@]}" =~ "@zinit-scheduler" ]] && {
    add-zsh-hook -d chpwd "@zinit-scheduler"
    sched | grep -qo scheduler && sched -1
  }
}

__precmd_brew_with_bundle() {
  local _precmd_result=$?
  local _precmd=($__remember_command)
  unset __remember_command

  if [[ ${_precmd[1]} != "brew" ]]; then
    return
  fi

  if [ $_precmd_result -ne 0 ]; then
    return
  fi

  case "${_precmd:1}" in
    *" uninstall "* | *" upgrade "* | *" rm "* | *" install "* | *" reinstall "* | *" tap "* | *" untap "*)
      echo "Running brew bundle ..."
      brew bundle dump \
        --file={{ .customDataDir }}/brewfile \
        --force 
      ;;
    *)
      ;;
  esac

   if (( $+commands[icon] )); then
      icon set
   fi
}

preexec_functions+=(__preexec_del_zinit_sched __preexec_remember_command)
precmd_functions+=(__precmd_brew_with_bundle)
